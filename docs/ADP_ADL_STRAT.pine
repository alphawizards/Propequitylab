//@version=6
// ADL + ADP Combo Strategy
// Entry  : ADL > 50-day SMA AND ADP (3D) > 50
// Exit   : ADL < 50-day SMA AND ADP (3D) < 50

strategy(title='ADL + ADP Combo', shorttitle='ADL/ADP Strat', overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=95,
     commission_type=strategy.commission.percent, commission_value=0.1, slippage=2)

// ══ INPUTS ═══════════════════════════════════════════════════════════════════

i_start_date     = input.time(timestamp('01 Jan 2020 00:00'), 'Start Date',          group='Backtest Window')
i_end_date       = input.time(timestamp('01 Jan 2100 00:00'), 'End Date',            group='Backtest Window')

i_adl_len        = input.int(50,    'ADL SMA Length',   minval=1,                   group='ADL Settings')
i_ad_weight      = input.float(0.0, 'A/D Weight',       minval=0.0, maxval=1.0,     group='Shared AD Settings',
     tooltip='0 = close-location weighted, 1 = full OBV-style. Applied to both ADL and ADP.')
i_price          = input.bool(false, 'Factor Price (Money Flow)',                    group='Shared AD Settings')

i_adp_tf         = input.timeframe('3D', 'ADP Timeframe',                           group='ADP Settings')
i_adp_len        = input.int(14,    'ADP RMA Length',   minval=1,                   group='ADP Settings')
i_lookahead      = input.bool(false, 'Live Mode (use current bar ADP)',              group='ADP Settings',
     tooltip='OFF = waits for the ADP timeframe bar to close (clean backtesting). ON = uses the in-progress bar value for real-time signals.')

i_qty_pct        = input.float(95, 'Position Size %', minval=1, maxval=100, step=1, group='Risk',
     tooltip='Percent of equity per trade. Keep ≤95 so commission and slippage never push the fill above available cash (cash-only simulation, no margin calls). Lower to 50 on volatile symbols like BTC to reduce single-trade drawdown.')

i_allow_short    = input.bool(false, 'Enable Short Trading',                        group='Filters',
     tooltip='When ON, enters short when ADL < SMA and ADP < 50. When OFF, long-only.')
i_slope_filter   = input.bool(false, 'Enable ADL Slope Filter',                     group='Filters',
     tooltip='Only enter when the ADL SMA is rising. Filters entries in flat/choppy ADL zones.')
i_slope_lookback = input.int(5,     'Slope Lookback Bars', minval=1,                group='Filters')
i_atr_stop       = input.bool(false, 'Enable ATR Trailing Stop',                    group='Filters',
     tooltip='Chandelier-style exit: trails highest high minus ATR multiplier. Exits if price closes below the stop.')
i_atr_len        = input.int(14,    'ATR Length',           minval=1,               group='Filters')
i_atr_mult       = input.float(2.0, 'ATR Multiplier',       minval=0.1, step=0.1,   group='Filters')

// ══ SHARED AD RATIO FUNCTION ═════════════════════════════════════════════════

f_ad_raw(float ad_weight, bool price_enable) =>
    ad_ratio = nz(ta.change(close) / ta.tr(true))
    ad_ratio := (1.0 - ad_weight) * ad_ratio + math.sign(ad_ratio) * ad_weight
    vol      = price_enable ? volume * hlc3 : volume
    vol * ad_ratio

// ══ ADL — CHART TIMEFRAME ════════════════════════════════════════════════════

ad_raw          = f_ad_raw(i_ad_weight, i_price)
adl             = ta.cum(ad_raw)
adl_sma         = ta.sma(adl, i_adl_len)
adl_bull        = adl > adl_sma
adl_sma_rising  = adl_sma > adl_sma[i_slope_lookback]

// ══ ADP — REQUESTED TIMEFRAME ════════════════════════════════════════════════

f_adp(int len, float ad_weight, bool price_enable) =>
    ad_ratio = nz(ta.change(close) / ta.tr(true))
    ad_ratio := (1.0 - ad_weight) * ad_ratio + math.sign(ad_ratio) * ad_weight
    vol      = price_enable ? volume * hlc3 : volume
    ad       = vol * ad_ratio
    50.0 * (1.0 + ta.rma(ad, len) / ta.rma(math.abs(ad), len))

adp = request.security(syminfo.tickerid, i_adp_tf,
     f_adp(i_adp_len, i_ad_weight, i_price),
     lookahead=i_lookahead ? barmerge.lookahead_on : barmerge.lookahead_off)

adp_bull = adp > 50

// ══ ATR TRAILING STOP ════════════════════════════════════════════════════════

atr_val          = ta.atr(i_atr_len)
var float trail_stop = na

if strategy.position_size > 0 and i_atr_stop
    bars_in_trade   = bar_index - strategy.opentrades.entry_bar_index(0) + 1
    highest_high    = ta.highest(high, bars_in_trade)
    trail_stop     := highest_high - i_atr_mult * atr_val
else if strategy.position_size == 0
    trail_stop     := na

atr_stop_hit = i_atr_stop and strategy.position_size > 0 and not na(trail_stop) and close < trail_stop

// ══ STRATEGY LOGIC ═══════════════════════════════════════════════════════════

in_window       = time >= i_start_date and time <= i_end_date
slope_ok        = i_slope_filter ? adl_sma_rising : true
long_condition  = adl_bull and adp_bull and slope_ok and in_window
short_condition = i_allow_short and not adl_bull and not adp_bull and in_window
exit_long       = (not adl_bull and not adp_bull) or not in_window
exit_short      = adl_bull and adp_bull

entry_qty = (strategy.equity * i_qty_pct / 100) / (close * syminfo.pointvalue)

if long_condition and strategy.position_size <= 0
    strategy.entry('Long', strategy.long, qty=entry_qty)

if (exit_long or atr_stop_hit) and strategy.position_size > 0
    strategy.close('Long')

if short_condition and strategy.position_size >= 0
    strategy.entry('Short', strategy.short, qty=entry_qty)

if (exit_short or not in_window) and strategy.position_size < 0
    strategy.close('Short')

// ══ PLOTS ════════════════════════════════════════════════════════════════════

// ADL and SMA in data window only — keeps price scale clean
plot(adl,     title='ADL',     display=display.data_window)
plot(adl_sma, title='ADL SMA', display=display.data_window)

// ADP in data window only
plot(adp, title='ADP (3D)', display=display.data_window)

// Background: green when in trade, red when flat
bgcolor(strategy.position_size > 0 ? color.new(color.green, 90) :
     strategy.position_size < 0 ? color.new(color.red, 90) :
     color.new(color.gray, 95),
     title='Position Background')
